<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintDimensionRatio="1:1"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/imageButton"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="#000000ff"
                android:contentDescription="@string/menu"
                app:srcCompat="@android:drawable/ic_menu_search" />


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                >
            <ImageView
                android:id="@+id/imageView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/title_logo"
                app:srcCompat="@android:drawable/ic_popup_sync" />

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/alexandria"
                    android:gravity="center"
                    android:text="@string/title"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>


            <TextView
                android:id="@+id/Balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|end"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="5dp"
                android:background="#000000ff"
                android:fontFamily="@font/montserrat_bold"
                android:text="@string/balance"
                android:textSize="20sp" />


        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded"
            android:backgroundTint="#FFD41D"
            android:orientation="vertical"
            android:paddingTop="15dp"
            android:paddingHorizontal="15dp"
            android:paddingBottom="10dp"
            android:layout_marginVertical="50dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/dices_bg"
                android:orientation="horizontal"
                android:paddingStart="2dp"
                android:paddingEnd="2dp">

                <ImageButton
                    android:id="@+id/dice1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/kostka"
                    android:backgroundTint="#00000000"
                    android:contentDescription="0"
                    android:onClick="rollDice"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:scaleX="2"
                    android:scaleY="2"
                    android:src="@drawable/question" />

                <FrameLayout
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="#000000"/>

                <ImageButton
                    android:id="@+id/dice2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/kostka"
                    android:backgroundTint="#00000000"
                    android:contentDescription="0"
                    android:onClick="rollDice"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:scaleX="2"
                    android:scaleY="2"
                    android:src="@drawable/question" />

                <FrameLayout
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="#000000"/>

                <ImageButton
                    android:id="@+id/dice3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/kostka"
                    android:backgroundTint="#00000000"
                    android:contentDescription="0"
                    android:onClick="rollDice"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:scaleX="2"
                    android:scaleY="2"
                    android:src="@drawable/question" />

                <FrameLayout
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="#000000"/>

                <ImageButton
                    android:id="@+id/dice4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/kostka"
                    android:backgroundTint="#00000000"
                    android:contentDescription="0"
                    android:onClick="rollDice"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:scaleX="2"
                    android:scaleY="2"
                    android:src="@drawable/question" />

                <FrameLayout
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="#000000"/>

                <ImageButton
                    android:id="@+id/dice5"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="2dp"
                    android:background="@drawable/kostka"
                    android:backgroundTint="#00000000"
                    android:contentDescription="0"
                    android:onClick="rollDice"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:scaleX="2"
                    android:scaleY="2"
                    android:src="@drawable/question" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:fontFamily="@font/alexandria"
                    android:text="@string/score"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

                <ImageButton
                    android:id="@+id/playButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end"
                    android:background="@drawable/lightrounded"
                    android:backgroundTint="#040423"
                    android:contentDescription="@string/next_round"
                    android:cropToPadding="true"
                    android:onClick="rollDices"
                    android:scaleX="1"
                    android:scaleY="1"
                    app:srcCompat="@android:drawable/ic_media_ff" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp">

            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"
                android:text="@string/continue_playing"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginStart="15dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="190dp">

                    <LinearLayout
                        android:id="@+id/gamesHub"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="15dp"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="180dp">

                            <ImageView
                                android:id="@+id/imageView653"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_margin="9dp"
                                android:background="@drawable/rounded"
                                android:backgroundTint="@color/black"
                                android:contentDescription="@string/blackjack"
                                android:padding="8dp"
                                app:srcCompat="@drawable/blackjack" />

                            <Button
                                android:id="@+id/butto54n"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="120dp"
                                android:backgroundTint="#F5C857"
                                android:contentDescription="@string/blackjack"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/play"
                                android:textColor="@color/white"
                                app:cornerRadius="13dp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="180dp">

                            <ImageView
                                android:id="@+id/imageView354"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_margin="9dp"
                                android:background="@drawable/rounded"
                                android:backgroundTint="@color/black"
                                android:padding="8dp"
                                app:srcCompat="@drawable/blackjack"
                                android:contentDescription="@string/blackjack"/>

                            <Button
                                android:id="@+id/button34"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="120dp"
                                android:backgroundTint="#F5C857"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/play"
                                android:textColor="@color/white"
                                app:cornerRadius="13dp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="180dp">

                            <ImageView
                                android:id="@+id/imageView33"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_margin="9dp"
                                android:background="@drawable/rounded"
                                android:backgroundTint="@color/black"
                                android:padding="8dp"
                                app:srcCompat="@drawable/blackjack"
                                android:contentDescription="@string/blackjack"/>

                            <Button
                                android:id="@+id/button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="120dp"
                                android:backgroundTint="#F5C857"
                                android:contentDescription="@string/blackjack"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/play"
                                android:textColor="@color/white"
                                app:cornerRadius="13dp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="180dp">

                            <ImageView
                                android:id="@+id/imageView343"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_margin="9dp"
                                android:background="@drawable/rounded"
                                android:backgroundTint="@color/black"
                                android:padding="8dp"
                                app:srcCompat="@drawable/blackjack"
                                android:contentDescription="@string/blackjack"/>

                            <Button
                                android:id="@+id/butto5454n"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="120dp"
                                android:backgroundTint="#F5C857"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/play"
                                android:textColor="@color/white"
                                app:cornerRadius="13dp" />
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="160dp"
                            android:layout_height="180dp">

                            <ImageView
                                android:id="@+id/imageView3"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center_horizontal"
                                android:layout_margin="9dp"
                                android:background="@drawable/rounded"
                                android:backgroundTint="@color/black"
                                android:padding="8dp"
                                app:srcCompat="@drawable/blackjack"
                                android:contentDescription="@string/blackjack"/>

                            <Button
                                android:id="@+id/button434353"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="120dp"
                                android:backgroundTint="#F5C857"
                                android:contentDescription="@string/blackjack"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="@string/play"
                                android:textColor="@color/white"
                                app:cornerRadius="13dp" />
                        </FrameLayout>

                    </LinearLayout>

                </HorizontalScrollView>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:layout_width="360dp"
                android:layout_height="200dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="25dp"
                android:background="@drawable/rounded"
                android:backgroundTint="#040405"
                tools:ignore="UselessParent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="95dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/kot11"
                            android:layout_width="270dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:contentDescription="@string/adcat"
                            app:srcCompat="@drawable/kot1" />

                        <ImageView
                            android:id="@+id/kot12"
                            android:layout_width="270dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:contentDescription="@string/adcat"
                            app:srcCompat="@drawable/kot2" />

                        <ImageView
                            android:id="@+id/kot13"
                            android:layout_width="270dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:contentDescription="@string/adcat"
                            app:srcCompat="@drawable/kot3" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="95dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/kot21"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:contentDescription="@string/adcat"
                            app:srcCompat="@drawable/kot1" />

                        <ImageView
                            android:id="@+id/kot24"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:contentDescription="@string/adcat"
                            app:srcCompat="@drawable/kot4" />

                    </LinearLayout>
                </LinearLayout>


                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/ad_blur_effect" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="5dp"
                    android:fontFamily="@font/amaranth"
                    android:text="@string/ad"
                    android:textColor="@color/white"
                    android:textFontWeight="400"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:targetApi="28" />
            </FrameLayout>
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>